#!/usr/bin/env bash
set -euo pipefail

# Resolve symlinks to find the real script location (works with Homebrew symlinks)
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_PATH" ]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"

# Homebrew layout: share/harnest/nest/...  Local dev: nest/...
if [ -d "$SCRIPT_DIR/../share/harnest/nest" ]; then
  SHARE_DIR="$SCRIPT_DIR/../share/harnest"
else
  SHARE_DIR="$SCRIPT_DIR/.."
fi
if [ -d "$SCRIPT_DIR/../share/harnest/lib" ]; then
  LIB_DIR="$SCRIPT_DIR/../share/harnest/lib"
else
  LIB_DIR="$SCRIPT_DIR/../lib"
fi
VERSION_FILE="$SCRIPT_DIR/../VERSION"

# Global config
HARNEST_CONFIG_DIR="$HOME/.config/harnest"
HARNEST_CONFIG="$HARNEST_CONFIG_DIR/config"

# Read version from VERSION file, fallback to "dev"
if [ -f "$VERSION_FILE" ]; then
  VERSION="$(cat "$VERSION_FILE")"
else
  # Homebrew installs may not have VERSION at prefix root; try share dir
  VERSION="dev"
fi

# ── Helpers ──────────────────────────────────────────────────────────────────

usage() {
  cat <<EOF
harnest $VERSION — Composable Claude Code agent team harness

Usage:
  harnest hatch [--chick <name>] [--force]   Scaffold a nest into the current project
  harnest fly [--chick <name>] [task...]     Launch agents in tmux split panes
  harnest land                               Stop tmux session and clean up
  harnest nest                               List available chicks
  harnest --chick <name>                     Set the global default chick
  harnest help                               Show this help message
  harnest version                            Print version

Options:
  --chick <name>   Chick (nest template) to use (default: fullstack)
  --force          Overwrite existing files during hatch
EOF
}

info()  { printf '  \033[32m✓\033[0m %s\n' "$1"; }
skip()  { printf '  \033[33m⊘\033[0m %s (already exists, use --force to overwrite)\n' "$1"; }
warn()  { printf '  \033[33m!\033[0m %s\n' "$1"; }
merge() { printf '  \033[36m⇄\033[0m %s\n' "$1"; }

get_default_chick() {
  if [ -f "$HARNEST_CONFIG" ]; then
    local chick
    chick="$(grep '^chick=' "$HARNEST_CONFIG" 2>/dev/null | cut -d= -f2)"
    if [ -n "$chick" ]; then
      echo "$chick"
      return
    fi
  fi
  echo "fullstack"
}

set_default_chick() {
  local name="$1"
  local chick_dir="$SHARE_DIR/nest/$name"
  if [ ! -d "$chick_dir" ]; then
    echo "Error: Chick '$name' not found." >&2
    cmd_nest >&2
    exit 1
  fi
  mkdir -p "$HARNEST_CONFIG_DIR"
  echo "chick=$name" > "$HARNEST_CONFIG"
  info "Default chick set to '$name' (saved to $HARNEST_CONFIG)"
}

resolve_chick_dir() {
  local name="$1"
  local chick_dir="$SHARE_DIR/nest/$name"
  if [ ! -d "$chick_dir" ]; then
    echo "Error: Chick '$name' not found." >&2
    cmd_nest >&2
    exit 1
  fi
  echo "$chick_dir"
}

# Copy a file from chick dir to a destination, respecting --force
copy_file() {
  local src="$1" dst="$2" force="$3"
  if [ -f "$dst" ] && [ "$force" != "true" ]; then
    skip "$dst"
    return 1
  fi
  mkdir -p "$(dirname "$dst")"
  cp "$src" "$dst"
  info "$dst"
  return 0
}

# ── CLAUDE.md handling ───────────────────────────────────────────────────────

MARKER_BEGIN="<!-- harnest:begin -->"
MARKER_END="<!-- harnest:end -->"

claudemd_section() {
  local chick_dir="$1"
  # Extract content from chick CLAUDE.md wrapped in markers
  printf '%s\n' "$MARKER_BEGIN"
  cat "$chick_dir/CLAUDE.md"
  printf '\n%s\n' "$MARKER_END"
}

handle_claudemd() {
  local chick_dir="$1" force="$2"
  if [ ! -f "CLAUDE.md" ]; then
    # No existing CLAUDE.md — write chick with markers
    claudemd_section "$chick_dir" > "CLAUDE.md"
    info "CLAUDE.md (created)"
  elif [ "$force" = "true" ]; then
    # Force mode — replace harnest section or create fresh
    if grep -q "$MARKER_BEGIN" "CLAUDE.md" 2>/dev/null; then
      replace_claudemd_section "$chick_dir"
      info "CLAUDE.md (harnest section replaced)"
    else
      printf '\n' >> "CLAUDE.md"
      claudemd_section "$chick_dir" >> "CLAUDE.md"
      info "CLAUDE.md (harnest section appended)"
    fi
  elif grep -q "$MARKER_BEGIN" "CLAUDE.md" 2>/dev/null; then
    # Already has harnest section
    skip "CLAUDE.md (harnest section)"
  else
    # Exists but no harnest section — append
    printf '\n' >> "CLAUDE.md"
    claudemd_section "$chick_dir" >> "CLAUDE.md"
    info "CLAUDE.md (harnest section appended)"
  fi
}

replace_claudemd_section() {
  local chick_dir="$1"
  local tmp
  tmp="$(mktemp)"
  local in_section=false
  local replaced=false
  while IFS= read -r line; do
    if [ "$line" = "$MARKER_BEGIN" ]; then
      in_section=true
      if [ "$replaced" = "false" ]; then
        claudemd_section "$chick_dir" >> "$tmp"
        replaced=true
      fi
      continue
    fi
    if [ "$line" = "$MARKER_END" ]; then
      in_section=false
      continue
    fi
    if [ "$in_section" = "false" ]; then
      printf '%s\n' "$line" >> "$tmp"
    fi
  done < "CLAUDE.md"
  mv "$tmp" "CLAUDE.md"
}

# ── settings.json deep merge ────────────────────────────────────────────────

merge_settings() {
  local src="$1" dst="$2" force="$3"
  if [ ! -f "$dst" ]; then
    mkdir -p "$(dirname "$dst")"
    cp "$src" "$dst"
    info "$dst (created)"
    return
  fi
  if [ "$force" = "true" ]; then
    cp "$src" "$dst"
    info "$dst (overwritten)"
    return
  fi
  # Deep merge using python3 (ships on macOS)
  local tmp
  tmp="$(mktemp)"
  python3 -c "
import json, sys

def deep_merge(base, overlay):
    for key, val in overlay.items():
        if key in base and isinstance(base[key], dict) and isinstance(val, dict):
            deep_merge(base[key], val)
        elif key in base and isinstance(base[key], list) and isinstance(val, list):
            # Union lists (preserve order, no duplicates)
            seen = set(json.dumps(x, sort_keys=True) if isinstance(x, (dict, list)) else x for x in base[key])
            for item in val:
                k = json.dumps(item, sort_keys=True) if isinstance(item, (dict, list)) else item
                if k not in seen:
                    base[key].append(item)
                    seen.add(k)
        else:
            base[key] = val
    return base

with open(sys.argv[1]) as f:
    existing = json.load(f)
with open(sys.argv[2]) as f:
    chick = json.load(f)

merged = deep_merge(existing, chick)
print(json.dumps(merged, indent=2))
" "$dst" "$src" > "$tmp" && mv "$tmp" "$dst"
  merge "Merged $dst"
}

# ── Nest command ─────────────────────────────────────────────────────────────

cmd_nest() {
  local nest_dir="$SHARE_DIR/nest"
  if [ ! -d "$nest_dir" ]; then
    echo "Error: Nest directory not found at $nest_dir" >&2
    echo "Is harnest installed correctly?" >&2
    exit 1
  fi
  local default_chick
  default_chick="$(get_default_chick)"
  echo "Available chicks:"
  for dir in "$nest_dir"/*/; do
    [ -d "$dir" ] || continue
    local name
    name="$(basename "$dir")"
    if [ "$name" = "$default_chick" ]; then
      echo "  $name (default)"
    else
      echo "  $name"
    fi
  done
}

# ── Hatch command ─────────────────────────────────────────────────────────────

cmd_hatch() {
  local force=false
  local chick=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --force) force=true; shift ;;
      --chick)
        if [ $# -lt 2 ]; then
          echo "Error: --chick requires a value"
          exit 1
        fi
        chick="$2"; shift 2 ;;
      *) echo "Unknown option: $1"; exit 1 ;;
    esac
  done

  # Resolve chick name
  if [ -z "$chick" ]; then
    chick="$(get_default_chick)"
  fi

  local chick_dir
  chick_dir="$(resolve_chick_dir "$chick")"

  echo "Hatching harnest ($chick chick) in $(pwd)..."
  echo ""

  # 1. harnest.yaml
  copy_file "$chick_dir/harnest.yaml" "./harnest.yaml" "$force" || true

  # 2. CLAUDE.md
  handle_claudemd "$chick_dir" "$force"

  # 3. Agent definitions
  mkdir -p ".claude/agents"
  for agent in "$chick_dir"/claude/agents/*.md; do
    [ -f "$agent" ] || continue
    local agent_name
    agent_name="$(basename "$agent")"
    copy_file "$agent" ".claude/agents/$agent_name" "$force" || true
  done

  # 4. settings.local.json.example
  if [ -f "$chick_dir/claude/settings.local.json.example" ]; then
    copy_file "$chick_dir/claude/settings.local.json.example" ".claude/settings.local.json.example" "$force" || true
  fi

  # 5. settings.json (deep merge)
  if [ -f "$chick_dir/claude/settings.json" ]; then
    merge_settings "$chick_dir/claude/settings.json" ".claude/settings.json" "$force"
  fi

  echo ""
  echo "Done! Next steps:"
  echo "  1. Customize harnest.yaml (optional)"
  echo "  2. Run 'claude' to start a harnest session"
}

# ── Fly command (tmux split-pane mode) ───────────────────────────────────────

cmd_fly() {
  local chick=""
  local task_desc=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --chick)
        if [ $# -lt 2 ]; then
          echo "Error: --chick requires a value" >&2
          exit 1
        fi
        chick="$2"; shift 2 ;;
      *)
        # Everything else is the task description
        task_desc="$*"
        break ;;
    esac
  done

  # ── Merge harnest.md instructions ───────────────────────────────────────
  if [ -f "harnest.md" ]; then
    local md_content
    md_content="$(cat harnest.md)"
    if [ -n "$task_desc" ]; then
      task_desc="${task_desc}

${md_content}"
    else
      task_desc="$md_content"
    fi
  fi

  # ── Validate prerequisites ──────────────────────────────────────────────
  if ! command -v tmux &>/dev/null; then
    echo "Error: tmux is required for 'harnest fly'. Install it with: brew install tmux" >&2
    exit 1
  fi
  if ! command -v claude &>/dev/null; then
    echo "Error: claude CLI is required. Install it with: brew install claude-code" >&2
    exit 1
  fi
  if [ ! -f "harnest.yaml" ]; then
    echo "Error: harnest.yaml not found. Run 'harnest hatch' first." >&2
    exit 1
  fi
  if [ -z "$task_desc" ]; then
    echo "Error: Task description is required. Pass it as an argument or create a harnest.md file." >&2
    echo "Usage: harnest fly [--chick <name>] [\"<task description>\"]" >&2
    exit 1
  fi

  # ── Parse harnest.yaml ─────────────────────────────────────────────────
  local config_json
  config_json="$(python3 "$LIB_DIR/harnest-parse-yaml.py" harnest.yaml)"

  local session_name
  session_name="$(echo "$config_json" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('tmux',{}).get('session_name','harnest'))")"

  local refresh_interval
  refresh_interval="$(echo "$config_json" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('tmux',{}).get('monitor',{}).get('refresh_interval',2))")"

  local branch_prefix
  branch_prefix="$(echo "$config_json" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('workflow',{}).get('branch_prefix','harnest/'))")"

  # Extract layout as flat list of pane names
  local layout_json
  layout_json="$(echo "$config_json" | python3 -c "import json,sys; d=json.load(sys.stdin); print(json.dumps(d.get('tmux',{}).get('layout',[])))")"

  local num_rows
  num_rows="$(echo "$layout_json" | python3 -c "import json,sys; print(len(json.load(sys.stdin)))")"

  # Check for existing session
  if tmux has-session -t "$session_name" 2>/dev/null; then
    echo "Error: tmux session '$session_name' already exists. Run 'harnest land' first." >&2
    exit 1
  fi

  # ── Resolve agent files ────────────────────────────────────────────────
  local agents_dir=".claude/agents"
  if [ ! -d "$agents_dir" ]; then
    # Fallback: try to find via chick
    if [ -z "$chick" ]; then
      chick="$(get_default_chick)"
    fi
    local cdir
    cdir="$(resolve_chick_dir "$chick")"
    agents_dir="$cdir/claude/agents"
  fi

  echo "Starting harnest tmux session ($session_name)..."
  echo ""

  # ── Create .harnest/ directory structure ───────────────────────────────
  rm -rf .harnest
  mkdir -p .harnest/{tasks,messages,status,worktrees,prompts}
  touch .harnest/log.jsonl

  # Write config.json
  local started_at
  started_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  python3 -c "
import json
config = {
    'session_name': '$session_name',
    'started_at': '$started_at',
    'task': $(python3 -c "import json; print(json.dumps('$task_desc'))"),
    'agents': ['architect', 'sr-engineer', 'jr-engineer-1', 'jr-engineer-2', 'test-engineer']
}
with open('.harnest/config.json', 'w') as f:
    json.dump(config, f, indent=2)
"
  info ".harnest/ directory created"

  # ── Create git worktrees for jr engineers ──────────────────────────────
  local current_branch
  current_branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "main")"

  for jr in jr-engineer-1 jr-engineer-2; do
    local wt_branch="${branch_prefix}${jr}-workspace"
    if git worktree list 2>/dev/null | grep -q ".harnest/worktrees/$jr"; then
      git worktree remove --force ".harnest/worktrees/$jr" 2>/dev/null || true
    fi
    git branch -D "$wt_branch" 2>/dev/null || true
    git worktree add -b "$wt_branch" ".harnest/worktrees/$jr" HEAD 2>/dev/null
    info "Worktree: .harnest/worktrees/$jr ($wt_branch)"
  done

  # ── Generate agent prompts ─────────────────────────────────────────────
  local protocol
  protocol="$(cat "$LIB_DIR/harnest-tmux-protocol.md")"

  local agents=("architect" "sr-engineer" "jr-engineer-1" "jr-engineer-2" "test-engineer")
  local agent_files=("architect.md" "sr-engineer.md" "jr-engineer.md" "jr-engineer.md" "test-engineer.md")

  for idx in "${!agents[@]}"; do
    local agent="${agents[$idx]}"
    local agent_file="${agent_files[$idx]}"
    local prompt_file=".harnest/prompts/${agent}.txt"
    local agent_md_path="${agents_dir}/${agent_file}"

    {
      echo "$protocol"
      echo ""
      echo "---"
      echo ""
      echo "# Your Identity"
      echo ""
      echo "You are **${agent}** in this harnest tmux session."
      echo ""
      if [ -f "$agent_md_path" ]; then
        # Strip frontmatter from agent .md
        sed '1{/^---$/!q;};1,/^---$/d' "$agent_md_path"
      fi
      echo ""
      echo "---"
      echo ""
      echo "# Task"
      echo ""
      echo "$task_desc"
    } > "$prompt_file"
    info "Prompt: .harnest/prompts/${agent}.txt"
  done

  # ── Log session start ──────────────────────────────────────────────────
  echo "{\"ts\":\"$started_at\",\"agent\":\"system\",\"action\":\"session_started\",\"message\":\"harnest tmux session started: $task_desc\"}" >> .harnest/log.jsonl

  # ── Create tmux session with panes ─────────────────────────────────────
  echo ""

  # Build the tmux layout from config
  # Layout is an array of rows, each row is an array of pane names
  # We create the session, then split panes accordingly

  # Create session with the first pane
  tmux new-session -d -s "$session_name" -x 200 -y 50

  # We need to create the right number of panes
  # Layout: [[a,b],[c,d],[e,f]] = 3 rows, 2 cols each
  # Strategy: split horizontally for rows, then vertically within each row

  # First, create all rows by splitting horizontally
  local row
  for ((row=1; row<num_rows; row++)); do
    tmux split-window -t "$session_name" -v
  done

  # Even out the horizontal splits
  tmux select-layout -t "$session_name" even-vertical

  # Now split each row into columns
  local pane_index=0
  local pane_names=()
  for ((row=0; row<num_rows; row++)); do
    local num_cols
    num_cols="$(echo "$layout_json" | python3 -c "import json,sys; print(len(json.load(sys.stdin)[$row]))")"

    # Select the first pane of this row
    tmux select-pane -t "$session_name:0.${pane_index}"

    # Get pane names for this row
    for ((col=0; col<num_cols; col++)); do
      local pname
      pname="$(echo "$layout_json" | python3 -c "import json,sys; print(json.load(sys.stdin)[$row][$col])")"
      pane_names+=("$pname")

      if [ "$col" -gt 0 ]; then
        tmux split-window -t "$session_name" -h
      fi
    done

    pane_index=$((pane_index + num_cols))
  done

  # Even out the layout
  tmux select-layout -t "$session_name" tiled

  # ── Launch commands in each pane ───────────────────────────────────────
  local pane_idx=0
  for pname in "${pane_names[@]}"; do
    if [ "$pname" = "monitor" ]; then
      tmux send-keys -t "$session_name:0.${pane_idx}" \
        "watch -n ${refresh_interval} -c 'bash \"$LIB_DIR/harnest-monitor.sh\"'" C-m
      info "Pane $pane_idx: monitor (watch)"
    else
      local prompt_file=".harnest/prompts/${pname}.txt"
      if [ -f "$prompt_file" ]; then
        # Use --print to run claude in non-interactive print mode with the prompt
        tmux send-keys -t "$session_name:0.${pane_idx}" \
          "claude -p \"\$(cat '$prompt_file')\"" C-m
        info "Pane $pane_idx: $pname (claude)"
      else
        warn "Pane $pane_idx: $pname (no prompt file found)"
      fi
    fi
    pane_idx=$((pane_idx + 1))
  done

  echo ""
  info "Tmux session '$session_name' created with ${#pane_names[@]} panes"
  echo ""
  echo "Attaching to tmux session..."
  echo "  Detach: Ctrl-b d"
  echo "  Land:   harnest land"
  echo ""

  # Attach to session
  tmux attach-session -t "$session_name"
}

# ── Land command ──────────────────────────────────────────────────────────────

cmd_land() {
  # Determine session name from .harnest/config.json or default
  local session_name="harnest"
  if [ -f ".harnest/config.json" ]; then
    session_name="$(python3 -c "import json; print(json.load(open('.harnest/config.json')).get('session_name','harnest'))" 2>/dev/null || echo "harnest")"
  fi

  # Kill tmux session
  if tmux has-session -t "$session_name" 2>/dev/null; then
    tmux kill-session -t "$session_name"
    info "Killed tmux session '$session_name'"
  else
    warn "No tmux session '$session_name' found"
  fi

  # Remove git worktrees
  if [ -d ".harnest/worktrees" ]; then
    for wt in .harnest/worktrees/*/; do
      [ -d "$wt" ] || continue
      local wt_name
      wt_name="$(basename "$wt")"
      git worktree remove --force "$wt" 2>/dev/null || true
      info "Removed worktree: $wt_name"
    done
  fi

  # Print task summary
  if [ -d ".harnest/tasks" ]; then
    echo ""
    echo "Task Summary:"
    local completed=0 in_progress=0 pending=0
    for f in .harnest/tasks/task-*.json; do
      [ -f "$f" ] || continue
      local status
      status="$(python3 -c "import json; print(json.load(open('$f')).get('status','unknown'))" 2>/dev/null || echo "unknown")"
      case "$status" in
        completed)   completed=$((completed + 1)) ;;
        in_progress) in_progress=$((in_progress + 1)) ;;
        pending)     pending=$((pending + 1)) ;;
      esac
    done
    printf '  \033[32m✓\033[0m Completed:   %d\n' "$completed"
    printf '  \033[33m⟳\033[0m In Progress: %d\n' "$in_progress"
    printf '  \033[90m○\033[0m Pending:     %d\n' "$pending"
  fi

  # Log session end
  if [ -f ".harnest/log.jsonl" ]; then
    echo "{\"ts\":\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\",\"agent\":\"system\",\"action\":\"session_stopped\",\"message\":\"harnest tmux session landed\"}" >> .harnest/log.jsonl
  fi

  # Archive option
  echo ""
  if [ -d ".harnest" ]; then
    printf "Archive .harnest/ directory? [y/N] "
    read -r answer
    if [[ "$answer" =~ ^[Yy] ]]; then
      local archive_name=".harnest-archive-$(date +%Y%m%d-%H%M%S)"
      mv .harnest "$archive_name"
      info "Archived to $archive_name"
    else
      rm -rf .harnest
      info "Removed .harnest/"
    fi
  fi
}

# ── Main ─────────────────────────────────────────────────────────────────────

case "${1:-help}" in
  hatch)      shift; cmd_hatch "$@" ;;
  fly)        shift; cmd_fly "$@" ;;
  land)       cmd_land ;;
  nest)       cmd_nest ;;
  --chick)
    if [ $# -lt 2 ]; then
      echo "Error: --chick requires a value"
      exit 1
    fi
    set_default_chick "$2" ;;
  version|--version|-v)  echo "harnest $VERSION" ;;
  help|--help|-h)        usage ;;
  *)          echo "Unknown command: $1"; usage; exit 1 ;;
esac
